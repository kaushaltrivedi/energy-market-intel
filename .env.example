# =============================================================================
# ENERGY MARKET INTEL — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# All secrets in staging/production are managed via AWS Secrets Manager.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development                          # development | staging | production
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR
APP_SECRET_KEY=generate-with-openssl-rand-hex-32
GRAPH_VERSION=1                              # Increment on LangGraph schema changes

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_LANGFUSE_TRACING=true
FEATURE_STRICT_DATA_RESIDENCY=true          # Enforces EU/UK data residency for all LLM calls
FEATURE_PII_SCRUBBING=true                  # Presidio PII scrubbing on all LLM inputs
FEATURE_CONTENT_SAFETY=false                # Azure Content Safety (enable in production)
LLM_MOCK_MODE=false                         # Set true in CI — uses recorded cassettes

# -----------------------------------------------------------------------------
# LLM Cost & Safety Controls
# -----------------------------------------------------------------------------
AGENT_TOKEN_BUDGET=50000                    # Max tokens per agent run
CIRCUIT_BREAKER_FAIL_THRESHOLD=5            # Failures before circuit opens
CIRCUIT_BREAKER_WINDOW_SECONDS=60
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=120
MONTHLY_LLM_BUDGET_USD=500                  # Monthly spend cap — alerts at 80%
MAX_CONCURRENT_AGENT_RUNS=5
AGENT_TIMEOUT_SECONDS=300

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------

# Azure OpenAI (PRIMARY — UK GDPR compliant, Data Zone Standard, uksouth)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
AZURE_OPENAI_DEPLOYMENT_GPT4O_MINI=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-large

# Anthropic / Claude (FALLBACK — EU inference via inference_geo header)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Google Vertex AI (SECONDARY FALLBACK — europe-west2/London)
# NOTE: Do NOT use Gemini direct API — US infrastructure only
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=europe-west2
VERTEX_MODEL=gemini-1.5-pro

# -----------------------------------------------------------------------------
# Vector Databases
# -----------------------------------------------------------------------------

# Pinecone (production vector store)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX_NAME=energy-intel-v1
ACTIVE_VECTOR_INDEX=energy-intel-v1         # Blue-green migration control

# Weaviate (local dev / self-hosted option)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=your-weaviate-api-key      # Leave blank for local dev
WEAVIATE_CLASS_PREFIX=EnergyIntel

# -----------------------------------------------------------------------------
# UK Energy Data Sources
# -----------------------------------------------------------------------------

# Elexon BMRS (Balancing Mechanism Reporting Service)
ELEXON_API_KEY=your-elexon-api-key
ELEXON_BASE_URL=https://data.elexon.co.uk/bmrs/api/v1

# Ofgem Data Portal
OFGEM_API_KEY=your-ofgem-api-key
OFGEM_BASE_URL=https://api.ofgem.gov.uk/v1

# Companies House API
COMPANIES_HOUSE_API_KEY=your-companies-house-api-key
COMPANIES_HOUSE_BASE_URL=https://api.company-information.service.gov.uk

# Energy News / RSS
NEWS_API_KEY=your-newsapi-key
NEWS_API_BASE_URL=https://newsapi.org/v2

# Refinitiv / LSEG Data (market pricing)
REFINITIV_APP_KEY=your-refinitiv-app-key

# Aurora Energy Research API (if licensed)
AURORA_API_KEY=your-aurora-api-key

# -----------------------------------------------------------------------------
# Infrastructure & Storage
# -----------------------------------------------------------------------------

# PostgreSQL (agent checkpointer + application data)
DATABASE_URL=postgresql://postgres:password@localhost:5432/energy_intel
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (caching, rate limiting, pub/sub)
REDIS_URL=redis://localhost:6379/0

# AWS (staging/production secret management + S3 report storage)
AWS_REGION=eu-west-2
AWS_S3_BUCKET_REPORTS=energy-intel-reports-prod
AWS_S3_BUCKET_ARTIFACTS=energy-intel-artifacts-prod
# Note: Use OIDC in CI, instance roles in production — never static keys

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------

# Langfuse (LLM tracing, cost tracking, prompt versioning)
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENVIRONMENT=development             # development | staging | production

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=energy-market-intel
OTEL_ENVIRONMENT=development

# Sentry (error tracking)
SENTRY_DSN=your-sentry-dsn
SENTRY_TRACES_SAMPLE_RATE=0.1

# PagerDuty (production alerting)
PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key

# -----------------------------------------------------------------------------
# Prefect (pipeline orchestration)
# -----------------------------------------------------------------------------
PREFECT_API_URL=http://localhost:4200/api
PREFECT_API_KEY=your-prefect-api-key

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=generate-with-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:3000
